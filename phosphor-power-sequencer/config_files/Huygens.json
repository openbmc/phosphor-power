{
    "comments": [
        "phosphor-power-sequencer configuration file for IBM Huygens systems.",
        "Huygens systems contain up to 8 chassis with host CPUs and memory.",
        "A chassis template is used to minimize duplicated data across chassis."
    ],
    "chassis_templates": [
        {
            "id": "huygens_chassis_template",
            "number": "${chassis_number}",
            "inventory_path": "/xyz/openbmc_project/inventory/system/chassis${chassis_number}",
            "power_sequencers": [
                {
                    "type": "UCD90320",
                    "i2c_interface": { "bus": "${i2c_bus}", "address": "0x11" },
                    "power_control_gpio_name": "power-control-chassis${chassis_number}",
                    "power_good_gpio_name": "power-good-chassis${chassis_number}",
                    "rails": [
                        {
                            "name": "12P0V",
                            "page": 0,
                            "is_power_supply_rail": true,
                            "check_status_vout": true,
                            "compare_voltage_to_limit": true
                        },
                        {
                            "name": "AVDD_1P5V",
                            "page": 1,
                            "check_status_vout": true,
                            "compare_voltage_to_limit": true
                        },
                        {
                            "name": "VDN_0P65V",
                            "page": 2,
                            "check_status_vout": true,
                            "compare_voltage_to_limit": true
                        },
                        {
                            "name": "VIO_0P90V",
                            "page": 3,
                            "check_status_vout": true,
                            "compare_voltage_to_limit": true
                        },
                        {
                            "name": "VDD_0",
                            "page": 4,
                            "check_status_vout": true,
                            "compare_voltage_to_limit": true
                        },
                        {
                            "name": "VDD_1",
                            "page": 5,
                            "check_status_vout": true,
                            "compare_voltage_to_limit": true
                        },
                        {
                            "name": "VDD_2",
                            "page": 6,
                            "check_status_vout": true,
                            "compare_voltage_to_limit": true
                        },
                        {
                            "name": "VDD_3",
                            "page": 7,
