                            "compare_voltage_to_limit": true
                        },
                        {
                            "name": "VCS_0",
                            "page": 12,
                            "check_status_vout": true,
                            "gpio": { "line": 72 }
                        },
                        {
                            "name": "VCS_1",
                            "page": 13,
                            "check_status_vout": true,
                            "gpio": { "line": 73 }
                        },
                        {
                            "name": "VCS_2",
                            "page": 14,
                            "check_status_vout": true,
                            "gpio": { "line": 74 }
                        },
                        {
                            "name": "VCS_3",
                            "page": 15,
                            "check_status_vout": true,
                            "gpio": { "line": 75 }
                        }
                    ]
                }
            ],
            "status_monitoring": {
                "is_present_monitored": true
            }
        }
    ],
    "chassis": [
        {
            "comments": ["Chassis 1"],
            "template_id": "huygens_chassis_template",
            "template_variable_values": {
                "chassis_number": "1",
