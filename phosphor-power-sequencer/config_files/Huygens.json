                            "compare_voltage_to_limit": true
                        },
                        {
                            "name": "VDD_4",
                            "page": 8,
                            "check_status_vout": true,
                            "compare_voltage_to_limit": true
                        },
                        {
                            "name": "VDD_5",
                            "page": 9,
                            "check_status_vout": true,
                            "compare_voltage_to_limit": true
                        },
                        {
                            "name": "VDD_6",
                            "page": 10,
                            "check_status_vout": true,
                            "compare_voltage_to_limit": true
                        },
                        {
                            "name": "VDD_7",
                            "page": 11,
